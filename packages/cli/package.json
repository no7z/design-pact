{
  "name": "@no7z/design-system",
  "version": "0.1.8",
  "description": "Set up and use your design system: install the Claude Code / Cursor skill, open the local studio, and turn design-system.md into token files. Zero backend, zero account.",
  "type": "module",
  "bin": {
    "design-system": "dist/cli.js"
  },
  "files": [
    "dist",
    "web",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node18 --clean",
    "bundle": "node scripts/bundle.mjs",
    "dev": "tsx src/cli.ts"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "tailwind",
    "css-variables",
    "ai",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "culori": "^4.0.2"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
